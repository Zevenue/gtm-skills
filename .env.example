# Apify — used by prospect-posts and linkedin-extract
# Get a token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# TheirStack — used by job-search
# Get a key at https://app.theirstack.com/settings/api
THEIRSTACK_API_KEY=

# Optional: default LinkedIn profile URL for linkedin-extract (your own handle)
LINKEDIN_DEFAULT_PROFILE_URL=
